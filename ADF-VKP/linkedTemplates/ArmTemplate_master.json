{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "ADF-VKP"
		},
		"lnk_srcDestDB_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'lnk_srcDestDB'"
		},
		"lnk_vkpblob_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'lnk_vkpblob'"
		},
		"lnk_srcDestDB_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "pmpvkp.database.windows.net"
		},
		"lnk_srcDestDB_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "srcDest_DB"
		},
		"lnk_srcDestDB_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "pmpvkp"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "ADF-VKP_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"lnk_srcDestDB_password": {
						"value": "[parameters('lnk_srcDestDB_password')]"
					},
					"lnk_vkpblob_connectionString": {
						"value": "[parameters('lnk_vkpblob_connectionString')]"
					},
					"lnk_srcDestDB_properties_typeProperties_server": {
						"value": "[parameters('lnk_srcDestDB_properties_typeProperties_server')]"
					},
					"lnk_srcDestDB_properties_typeProperties_database": {
						"value": "[parameters('lnk_srcDestDB_properties_typeProperties_database')]"
					},
					"lnk_srcDestDB_properties_typeProperties_userName": {
						"value": "[parameters('lnk_srcDestDB_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}